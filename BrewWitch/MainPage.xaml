<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BrewWitch.MainPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="StackLayout" x:Key="StackLayoutStyle">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup>
                            <VisualState x:Name="Portrait">
                                <VisualState.StateTriggers>
                                    <OrientationStateTrigger Orientation="Portrait"/>
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Property="Orientation" Value="Vertical"/>
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Landscape">
                                <VisualState.StateTriggers>
                                    <OrientationStateTrigger Orientation="Landscape"/>
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Property="Orientation" Value="Horizontal"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                        
                    </VisualStateGroupList>
                                        
                </Setter>
                
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="10">

        <ScrollView Grid.Row="0">
            <StackLayout 
                Grid.Row="0" 
                Spacing="15"
                Orientation="Vertical"
                Style="{StaticResource StackLayoutStyle}"
                >
                
                <Image
                    Source="beers.jpg"
                    HeightRequest="185"
                    WidthRequest="100"
                    Aspect="AspectFit"
                    SemanticProperties.Description="beers and hops"></Image>
                <Label Text=" 🍻 Brew Witch 🍻 "
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#D48806" />

                <Label Text="Find Local Breweries" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="DarkSlateBlue" />

                <Entry x:Name="SearchEntry" 
                        Placeholder="Enter a city (e.g., Perth)" />

                <Button Text="Search" 
                        Clicked="OnCounterClicked" />
            
                <!--List of Breweries -->
                <CollectionView x:Name="BreweryList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Padding="10">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding City}" TextColor="Gray" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Entry x:Name="EntryName"
                       Placeholder="Beer name" />

                <Entry x:Name="EntryStyle"
                       Placeholder="Style (e.g. Pale Ale" />

                <Entry x:Name="EntryAbv"
                       Placeholder="ABV (e.g. 5.2)"
                       Keyboard="Numeric" />

                <Button Text="ADD BEER"
                        Clicked="ButtonAddBeer_Clicked"
                        BackgroundColor="#D48806" />
        
            </StackLayout>
        </ScrollView>
        
        <!-- Beer list at the bottom -->
            <CollectionView Grid.Row="1"
                            x:Name="BeerCollectionView"
                            Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="0,8">
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#212121" />
                            <Label Text="{Binding Style}"
                                   TextColor="#616161" />
                            <Label Text="{Binding Abv, StringFormat='ABV: {0}%'}"
                                   TextColor="#D48806" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

    </Grid>
</ContentPage>