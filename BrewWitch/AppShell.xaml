<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BrewWitch.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BrewWitch"
    xmlns:views="clr-namespace:BrewWitch.Views"
    Title="BrewWitch">
    <!--FlyoutBehavior="Flyout" or use tabs-->


    <TabBar>
        <Tab Title="🍺 Find Breweries " Icon="dotnet_bot.png">
            <ShellContent
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="HomePage" />
        </Tab>

        <Tab Title="🔍 Search My Beers" Icon="dotnet_bot.png">
            <ShellContent
            ContentTemplate="{DataTemplate views:SearchPage}"
            Route="SearchPage" />
        </Tab>

        <Tab Title=" ➕ Add a Beer" Icon="dotnet_bot.png">
            <ShellContent
            ContentTemplate="{DataTemplate views:ItemPage}"
            Route="ItemPage" />
        </Tab>

        <Tab Title="⚙️ Settings" Icon="dotnet_bot.png">
            <ShellContent
            ContentTemplate="{DataTemplate views:Settings}"
            Route="Settings" />
        </Tab>
    </TabBar>
</Shell>
